# ===== AI 模型配置 =====
# 必填：你的 API Key（支持 OpenAI 兼容接口）
OPENAI_API_KEY=sk-your-api-key-here

# 可选：自定义 API 地址（使用 DeepSeek / 通义千问 / 其他兼容服务时填写）
# DeepSeek: https://api.deepseek.com/v1
# 阿里百炼: https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_BASE=https://api.deepseek.com/v1

# 可选：模型名称（默认 deepseek-v4-flash，速度最快）
# 支持所有 OpenAI 兼容模型
AI_MODEL=deepseek-v4-flash

# ===== 数据库 =====
# SQLite 文件路径（MVP 阶段，后续可改为 PostgreSQL 连接字符串）
DATABASE_URL="file:./prisma/dev.db"

# ===== NextAuth 鉴权 =====
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-change-in-production

# 邮件服务器（NextAuth Email Provider）
# 推荐服务：Resend / Mailtrap / Brevo
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
# EMAIL_FROM=AI工具集 <noreply@example.com>

# ===== 超级管理员 & 开发模式 =====
# 超级管理员邮箱（生产环境拥有无限权限）
SUPER_ADMIN_EMAIL=your@email.com
# 开发环境绕过登录（本地开发设 true，生产环境设 false）
DEV_BYPASS=true
