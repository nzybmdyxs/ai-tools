// ==========================================
// AI工具集 - 会员体系数据库设计
// 使用 SQLite（MVP 阶段，后续可迁移到 PostgreSQL）
// ==========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 注册/登录用户
model User {
  id        String   @id @default(cuid())
  email     String   @unique

  // 会员等级：FREE | PRO（SQLite 不支持 enum，用 String）
  plan      String   @default("FREE")

  // AI 生成次数（FREE 用户默认 30 次）
  credits   Int      @default(30)

  // 邀请码（8位字母数字，注册时自动生成）
  inviteCode String? @unique
  // 邀请人 ID（谁邀请了这个用户）
  inviterId  String?
  // 邀请人
  inviter    User?   @relation("UserInvites", fields: [inviterId], references: [id])
  // 被邀请的用户列表
  invitees   User[]  @relation("UserInvites")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders       Order[]
  diagrams     Diagram[]
  favorites    Favorite[]
  subscription Subscription?

  // 用量追踪
  usages     Usage[]
  dailyUsage DailyUsage[]

  // NextAuth 关联
  accounts  Account[]
  sessions  Session[]
}

// 订阅记录（会员过期管理）
model Subscription {
  id        String    @id @default(cuid())

  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 订阅方案：FREE | PRO
  plan      String    @default("FREE")

  // 状态：ACTIVE | EXPIRED | CANCELLED
  status    String    @default("ACTIVE")

  // 过期时间
  expireAt  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// 生成历史（AI 生成的图表记录）
model Diagram {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  type      String    // flow | er | uml | sequence | gantt | mindmap
  prompt    String    // 用户输入的原始文本
  result    String    // Mermaid 代码

  // V1.2: Mermaid 渲染追踪
  renderError String?  // 上次渲染错误信息
  repaired    Boolean  @default(false)  // 是否经过自动修复

  // V2: 公开分享
  public     Boolean  @default(false)
  views      Int      @default(0)   // 分享页浏览数

  versions   DiagramVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 模板库
model Template {
  id          String @id @default(cuid())

  title       String
  category    String  // 电商系统 | 博客系统 | 学生管理 | 医院管理 | 库存管理
  description String
  preview     String  // SVG 预览或描述
  code        String  // Mermaid 代码

  views       Int      @default(0)  // 浏览次数
  uses        Int      @default(0)  // 使用次数

  createdAt   DateTime @default(now())
}

// 收藏
model Favorite {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  diagramId String

  createdAt DateTime @default(now())

  @@unique([userId, diagramId])
}

// 游客设备追踪（未登录用户，按设备 ID 限制导出次数 + AI生成次数）
model GuestUsage {
  id          String   @id @default(cuid())

  deviceId    String   @unique

  // 已导出次数
  exportCount Int      @default(0)

  // AI 生成次数（游客上限 3 次）
  aiCount     Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 订单记录
model Order {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  amount    Float

  // 订单类型：CREDITS | MONTHLY | YEARLY
  type      String

  // 订单状态：PENDING | PAID | FAILED
  status    String   @default("PENDING")

  // ===== 支付相关字段 =====
  // 商户订单号（唯一）
  tradeNo   String?  @unique
  // 商品 ID（对应 pricing.ts 中的产品）
  productId String?
  // 购买的次数（CREDITS 类型订单使用）
  credits   Int?
  // 支付完成时间
  paidAt    DateTime?
  // 会员到期时间（MONTHLY/YEARLY 订单使用）
  expireAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 图表版本历史
model DiagramVersion {
  id        String   @id @default(cuid())

  diagramId String
  diagram   Diagram  @relation(fields: [diagramId], references: [id], onDelete: Cascade)

  result    String    // 该版本的 Mermaid 代码
  version   Int       // 版本号

  createdAt DateTime @default(now())

  @@unique([diagramId, version])
}

// Token 使用日志（AI 成本追踪）
model Usage {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  model     String    // 模型名称
  inputTokens  Int
  outputTokens Int
  totalTokens  Int
  cost      Float     // 成本（美元）

  createdAt DateTime @default(now())
}

// 每日使用次数追踪
model DailyUsage {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date      String    // YYYY-MM-DD
  count     Int       @default(0)

  createdAt DateTime @default(now())

  @@unique([userId, date])
}

// ========== NextAuth 所需模型 ==========

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
